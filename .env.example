# ============================================================
# Sports Edge AI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha as chaves abaixo
# ============================================================

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# The Odds API — https://the-odds-api.com (plano gratuito: 500 req/mês)
ODDS_API_KEY=

# RapidAPI (ESPN API e outras) — https://rapidapi.com (plano gratuito disponível)
RAPIDAPI_KEY=

# ============================================================
# Configurações opcionais
# ============================================================

# Nível de log: DEBUG | INFO | WARNING | ERROR (padrão: INFO)
LOG_LEVEL=INFO

# Intervalo de atualização de odds em segundos (padrão: 300 = 5 min)
REFRESH_INTERVAL=300

# Banca inicial em R$ (padrão: 100)
BANKROLL=100
