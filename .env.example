# ------------------------------------------------------------------------------
# SPORTS EDGE AI PRO - ARQUIVO DE EXEMPLO DE CONFIGURAÇÃO (.env)
# Copie este arquivo para um novo arquivo chamado .env e preencha seus valores.
# ------------------------------------------------------------------------------

# --- APIs DE DADOS (Obrigatórias) ---
THE_ODDS_API_KEY=sua_chave_aqui       # Obtenha em the-odds-api.com
PANDASCORE_API_KEY=sua_chave_aqui     # Obtenha em pandascore.co

# --- APIs DE IA (Mínimo uma obrigatória) ---
GROQ_API_KEY=sua_chave_aqui           # Principal (groq.com)
ANTHROPIC_API_KEY=                    # Opcional para Deep Analysis
CEREBRAS_API_KEY=                     # Opcional fallback (cerebras.ai)

# --- COMUNICAÇÃO (Obrigatórias) ---
TELEGRAM_BOT_TOKEN=8634273100:AA...   # Token do @BotFather
TELEGRAM_CHAT_ID=7889694921           # ID do grupo/canal para sinais
OWNER_TELEGRAM_ID=7889694921          # Seu ID pessoal para comandos de admin

# --- BANCO DE DADOS ---
DATABASE_PATH=data/sports_edge.db      # Caminho para o arquivo SQLite

# --- GESTÃO DE RISCO E BANCA ---
BANKROLL=20.00                        # Valor total da banca inicial
MIN_EDGE_THRESHOLD=0.06               # Edge mínimo para gerar sinal (0.06 = 6%)
MIN_CONFIDENCE_THRESHOLD=60           # Confiança mínima da IA (0-100)
KELLY_FRACTION=0.25                   # Fração do Critério de Kelly (ex: 0.25 = 1/4 Kelly)
MAX_STAKE_PERCENT=0.05                # Aposta máxima permitida (0.05 = 5% da banca)
PROFIT_SHARE_PCT=0.10                 # Taxa de lucro para gestão (ex: 0.10 = 10%)

# --- SISTEMA ---
LOG_LEVEL=INFO                        # DEBUG, INFO, WARNING, ERROR
REFRESH_INTERVAL=3600                 # Intervalo entre verificações (segundos)
ENABLE_FOOTBALL=true
ENABLE_BASKETBALL=true
ENABLE_ESPORTS=true
ENABLE_DEEP_ANALYSIS=false
